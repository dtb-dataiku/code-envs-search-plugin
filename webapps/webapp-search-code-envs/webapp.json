// This file is the descriptor for webapp webapp-search-code-envs
{
    "meta": {
        "label": "Search Code Environments Webapp",
        "description": "Search for Python or R packages in code environments",
        "icon": "fas fa-search"
    },
    "baseType": "DASH", // WARNING: do not change
    "hasBackend": "true",
    "noJSSecurity": "true",
    "standardWebAppLibraries": null,
    "hideWebAppConfig": "true",
    "params": [
        {
            "name": "code_envs_ds_name",
            "type": "DATASET",
            "label": "Dataset",
            "description": "Select a dataset containing code environment data",
            "mandatory": true
        },
        {
            "name": "view_settings",
            "type": "BOOLEAN",
            "label": "View settings",
            "defaultValue": false,
            "mandatory": true
        },
        {
            "name": "exclude_plugins",
            "type": "BOOLEAN",
            "label": "Exclude Plugin Code Environments",
            "description": "Exclude code environments managed by plugins",
            "defaultValue": true,
            "visibilityCondition": "model.view_settings"
        },
        {
            "name": "exclude_solutions",
            "type": "BOOLEAN",
            "label": "Exclude Solution Code Environments",
            "description": "Exclude code environments managed by solutions",
            "defaultValue": true,
            "visibilityCondition": "model.view_settings"
        },
        {
            "name": "exclude_internal",
            "type": "BOOLEAN",
            "label": "Exclude Internal Code Environments",
            "description": "Exclude code environments for internal Dataiku-related features",
            "defaultValue": true,
            "visibilityCondition": "model.view_settings"
        }
    ],
    "roles": []
}
